# ===================================
# BACKEND ENVIRONMENT VARIABLES
# ===================================
# Copy file ini ke .env untuk development/production

# Server Configuration
PORT=3000
NODE_ENV=development
# Production: NODE_ENV=production

# Database - Supabase
SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# JWT Secret (generate random string)
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long

# CORS Configuration
CORS_ORIGIN=http://localhost:5173
# Production (multiple domains): https://nexo.vercel.app,https://www.nexo.com

# AI Services - OpenAI
OPENAI_API_KEY=sk-...

# OR Azure OpenAI (uncomment if using Azure)
# AZURE_OPENAI_API_KEY=your-azure-key
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4
# AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Cloudflare R2 Storage (optional)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=nexo-assets
R2_PUBLIC_URL=https://nexo-assets.your-domain.com

# OR AWS S3 (alternative to R2)
# AWS_REGION=ap-southeast-1
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_S3_BUCKET=nexo-assets

# Optional: Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Optional: AI Caching
AI_RECOMMENDATION_CACHE_TTL_MS=600000
